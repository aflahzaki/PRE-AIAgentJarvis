# ============================================
# J.A.R.V.I.S v2 - Environment Configuration
# ============================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# Ollama (Local - Install from https://ollama.ai)
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL_SMALL=llama3.2:3b
OLLAMA_MODEL_MEDIUM=qwen2.5-coder:7b

# Groq (Cloud Free Tier - Get key from https://console.groq.com)
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# Google Gemini (Free Tier - Get key from https://aistudio.google.com/apikey)
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash

# OpenRouter (Free models available - Get key from https://openrouter.ai/keys)
OPENROUTER_API_KEY=your-openrouter-api-key-here
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# MySQL/MariaDB (accessible via phpMyAdmin)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=jarvis_db

# Fallback to SQLite if MySQL unavailable
DB_FALLBACK_SQLITE=true

# Web Dashboard
WEB_HOST=0.0.0.0
WEB_PORT=8000

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
TELEGRAM_ALLOWED_USERS=your-chat-id-here

# Voice Interface
VOICE_MODEL=base
VOICE_LANGUAGE=en
TTS_VOICE=en-US-AriaNeural

# Proactive Engine
PROACTIVE_ENABLED=false
PROACTIVE_INTERVAL_MINUTES=15
